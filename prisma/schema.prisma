generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Enums ──────────────────────────────────────────────────────────────────

// Stored as strings in SQLite (no native enum support)
// Values: STUDENT | LECTURER | ADMIN
// ADMIN can also act as lecturer (full access)

// ─── Models ─────────────────────────────────────────────────────────────────

model User {
  id             String   @id @default(cuid())
  name           String
  email          String   @unique
  password       String?  // bcrypt hash — only for dev/credentials login
  azureId        String?  @unique
  role           String   @default("STUDENT") // STUDENT | LECTURER | ADMIN
  // Student-specific
  studentId      String?
  level          String?  // BACHELOR | MASTER
  programme      String?  // BBA | IBA | DIGI | MBA | MDBA | MEBI | DGOV
  specialisation String?  // MARKETING | GLOBAL_MANAGEMENT | FINANCE | SUSTAINABLE_BUSINESS
  // Timestamps
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Supervisor capacity — total students they can supervise across both workflows
  supervisorCapacity   Int     @default(5)

  // Relations
  topics               Topic[]               @relation("LecturerTopics")
  preferences          Preference[]
  match                Match?
  coSupervisedMatches  MatchCoSupervisor[]   @relation("CoSupervisedMatches")
  // Own-topic workflow relations
  ownTopicRequest      OwnTopicRequest?      @relation("StudentOwnTopicRequest")
  ownTopicSupervisorRequests OwnTopicSupervisorRequest[] @relation("LecturerOwnTopicRequests")
}

model Semester {
  id                String   @id @default(cuid())
  name              String   // e.g. "HS 2025/26"
  lecturerDeadline  DateTime // last date lecturers can add/edit topics
  studentDeadline   DateTime // last date students can submit preferences
  isActive          Boolean  @default(false)
  matchingApproved  Boolean  @default(false) // admin approved → ready to run
  matchingRun       Boolean  @default(false) // algorithm has been executed
  resultsPublished  Boolean  @default(false) // admin reviewed & published → visible to lecturers/students
  emailsSent        Boolean  @default(false) // results sent to students/lecturers
  createdAt         DateTime @default(now())

  topics           Topic[]
  preferences      Preference[]
  matches          Match[]
  ownTopicRequests OwnTopicRequest[]
}

model Topic {
  id              String   @id @default(cuid())
  title           String
  description     String?
  method          String   // QUANTITATIVE | QUALITATIVE | DESIGN_SCIENCE_RESEARCH | LITERATURE_REVIEW
  language        String   // GERMAN | ENGLISH | BOTH
  level           String   // BACHELOR | MASTER
  // JSON arrays stored as strings e.g. '["BBA","IBA"]'
  programmes      String
  specialisations String   @default("[]") // only relevant for BACHELOR
  maxStudents     Int      @default(1)    // 1–8 per topic
  isActive        Boolean  @default(true)

  semesterId  String
  semester    Semester @relation(fields: [semesterId], references: [id], onDelete: Cascade)
  lecturerId  String
  lecturer    User     @relation("LecturerTopics", fields: [lecturerId], references: [id])

  preferences   Preference[]
  matches       Match[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Preference {
  id         String   @id @default(cuid())
  rank       Int      // 1 = top preference, 4 = lowest
  // Priority date — set on FIRST submission, NOT updated on edits
  priorityDate DateTime @default(now())
  updatedAt    DateTime @updatedAt

  studentId  String
  student    User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  topicId    String
  topic      Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
  semesterId String
  semester   Semester @relation(fields: [semesterId], references: [id], onDelete: Cascade)

  @@unique([studentId, rank, semesterId])
  @@unique([studentId, topicId, semesterId])
}

model Match {
  id          String   @id @default(cuid())
  matchedRank Int      // which preference rank was fulfilled (1–4), 0 = manual/unmatched
  matchedAt   DateTime @default(now())

  studentId  String   @unique // one student → one match
  student    User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  topicId    String
  topic      Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
  semesterId String
  semester   Semester @relation(fields: [semesterId], references: [id], onDelete: Cascade)

  progress      ThesisProgress?
  grading       ThesisGrading?
  files         ThesisFile[]
  coSupervisors MatchCoSupervisor[]
}

model MatchCoSupervisor {
  matchId    String
  match      Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  lecturerId String
  lecturer   User   @relation("CoSupervisedMatches", fields: [lecturerId], references: [id], onDelete: Cascade)
  addedAt    DateTime @default(now())

  @@id([matchId, lecturerId])
}

model ThesisProgress {
  id                  String    @id @default(cuid())
  matchId             String    @unique
  match               Match     @relation(fields: [matchId], references: [id], onDelete: Cascade)

  kickoffCompleted             Boolean   @default(false)
  kickoffCompletedAt           DateTime?
  kickoffStudentConfirmed      Boolean   @default(false)
  kickoffStudentConfirmedAt    DateTime?

  proposalSubmitted            Boolean   @default(false)
  proposalSubmittedAt          DateTime?
  proposalMeetingCompleted     Boolean   @default(false)
  proposalMeetingCompletedAt   DateTime?
  proposalMeetingStudentConfirmed   Boolean   @default(false)
  proposalMeetingStudentConfirmedAt DateTime?
  proposalApproved    Boolean   @default(false)
  proposalApprovedAt  DateTime?
  proposalFeedback    String?
  midtermSubmitted    Boolean   @default(false)
  midtermSubmittedAt  DateTime?
  midtermApproved     Boolean   @default(false)
  midtermApprovedAt   DateTime?
  midtermFeedback     String?

  notifyOnUpload      Boolean   @default(false)

  // How many times each milestone has been uploaded (max 2 for initial, bypassed on rework)
  proposalUploadCount Int       @default(0)
  midtermUploadCount  Int       @default(0)

  // Lecturer can request a rework — student then gets a re-upload button
  proposalRejected    Boolean   @default(false)
  proposalRejectedAt  DateTime?
  midtermRejected     Boolean   @default(false)
  midtermRejectedAt   DateTime?

  finalThesisSubmitted    Boolean   @default(false)
  finalThesisSubmittedAt  DateTime?
  finalThesisApproved     Boolean   @default(false)
  finalThesisApprovedAt   DateTime?
  finalThesisRejected     Boolean   @default(false)
  finalThesisRejectedAt   DateTime?
  finalThesisUploadCount  Int       @default(0)

  finalPresentationSubmitted    Boolean   @default(false)
  finalPresentationSubmittedAt  DateTime?
  finalPresentationApproved     Boolean   @default(false)
  finalPresentationApprovedAt   DateTime?
  finalPresentationRejected     Boolean   @default(false)
  finalPresentationRejectedAt   DateTime?
  finalPresentationUploadCount  Int       @default(0)

  updatedAt           DateTime  @updatedAt
}

model ThesisGrading {
  id          String   @id @default(cuid())
  matchId     String   @unique
  match       Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  // JSON: { "S1": { "score": 5.0, "comment": "" }, ... }
  gradingJson String   @default("{}")
  // JSON: { "LG_1_1": [1, 2, 0, 1], ... }
  aolJson     String    @default("{}")
  submittedAt DateTime?
  updatedAt   DateTime  @updatedAt
}

model ThesisFile {
  id              String   @id @default(cuid())
  matchId         String
  match           Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  milestone       String   // 'proposalSubmitted' | 'midtermSubmitted'
  originalName    String
  storedName      String
  mimeType        String?
  size            Int?
  seenByLecturer  Boolean  @default(false)
  uploadedAt      DateTime @default(now())
}

// ─── Own-Topic ("Eigenes Thema") workflow ────────────────────────────────────
// Parallel path: student proposes their own topic and solicits a supervisor.
// Unlike the preference/matching path, this is student-initiated and
// supervisor-approved, not algorithm-driven.

model OwnTopicRequest {
  id          String   @id @default(cuid())
  // One proposal per student per semester (unique per student — they can update it until submitted)
  studentId   String   @unique
  student     User     @relation("StudentOwnTopicRequest", fields: [studentId], references: [id], onDelete: Cascade)
  semesterId  String
  semester    Semester @relation(fields: [semesterId], references: [id], onDelete: Cascade)

  // Topic details provided by the student
  title       String
  description String?
  method      String   // mirrors Topic.method values
  language    String   // mirrors Topic.language values

  // Lifecycle: DRAFT → SUBMITTED → MATCHED | WITHDRAWN
  // DRAFT: student is still editing, no requests sent yet
  // SUBMITTED: at least one supervisor request sent
  // MATCHED: a supervisor accepted → Match record created
  // WITHDRAWN: student withdrew the proposal
  status      String   @default("DRAFT")

  supervisorRequests OwnTopicSupervisorRequest[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model OwnTopicSupervisorRequest {
  id                String          @id @default(cuid())
  ownTopicRequestId String
  ownTopicRequest   OwnTopicRequest @relation(fields: [ownTopicRequestId], references: [id], onDelete: Cascade)
  lecturerId        String
  lecturer          User            @relation("LecturerOwnTopicRequests", fields: [lecturerId], references: [id], onDelete: Cascade)

  // PENDING → ACCEPTED | REJECTED | WITHDRAWN (student withdrew before response)
  status            String   @default("PENDING")
  // Supervisor flags whether the topic fits the student's programme/specialisation
  specialisationFit Boolean?
  // Optional note from supervisor explaining acceptance or rejection
  responseNote      String?
  respondedAt       DateTime?

  createdAt DateTime @default(now())

  // A student can only request the same supervisor once per proposal
  @@unique([ownTopicRequestId, lecturerId])
}
