# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="file:./dev.db"

# ── File uploads ──────────────────────────────────────────────────────────────
# Absolute path where thesis files are stored on disk.
# In production, point this at a persistent volume (e.g. /app/data/uploads on
# Railway). If unset, falls back to `<cwd>/uploads` which is ephemeral on most
# hosting platforms — fine for local dev, data loss in production.
UPLOAD_DIR=""

# ── NextAuth (REQUIRED) ──────────────────────────────────────────────────────
# Generate a strong secret for production: openssl rand -base64 32
NEXTAUTH_SECRET="<generate-a-strong-random-secret>"
NEXTAUTH_URL="http://localhost:3000"

# ── Azure AD SSO (optional — leave empty to use credentials login only) ──────
AZURE_AD_CLIENT_ID=""
AZURE_AD_CLIENT_SECRET=""
AZURE_AD_TENANT_ID=""

# ── Email / SMTP (optional — falls back to console.log when not set) ─────────
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="thesis@bfh.ch"
